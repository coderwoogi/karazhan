[worldserver]

###################################################################################################
#   카라잔 강화 시스템 설정
###################################################################################################
#
#    ItemKarazhan.Enable
#        설명: 카라잔 강화 시스템 활성화 여부
#        기본값: 1 (활성화)
#                0 (비활성화)

ItemKarazhan.Enable = 1

#
#    ItemKarazhan.MaxEnhanceLevel.Weapon
#        설명: 무기류 최대 강화 레벨 (데이터베이스 설정 우선)
#        기본값: 100

# ItemKarazhan.MaxEnhanceLevel.Weapon = 100

#
#    ItemKarazhan.MaxEnhanceLevel.Armor
#        설명: 방어구 최대 강화 레벨 (데이터베이스 설정 우선)
#        기본값: 50

# ItemKarazhan.MaxEnhanceLevel.Armor = 50

#
#    ItemKarazhan.MaxEnhanceLevel.Trinket
#        설명: 장신구 최대 강화 레벨 (데이터베이스 설정 우선)
#        기본값: 30

# ItemKarazhan.MaxEnhanceLevel.Trinket = 30

#
#    ItemKarazhan.LogEnabled
#        설명: 강화 로그 기록 활성화 (karazhan_enhance_log 테이블)
#        기본값: 1 (활성화)
#                0 (비활성화)

ItemKarazhan.LogEnabled = 1

#
###################################################################################################